<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nitish — 2D & 3D Artist / Freelancer</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#0c0d10;
    --bg-panel:#151719;
    --bg-panel-2:#1b1e22;
    --line: rgba(255,255,255,.08);
    --line-soft: rgba(255,255,255,.05);
    --accent:#ff7a29;       /* render-highlight orange, viewport gizmo */
    --accent-soft: rgba(255,122,41,.14);
    --accent2:#3dd6ff;      /* wireframe cyan */
    --accent2-soft: rgba(61,214,255,.12);
    --text:#f4f2ec;
    --text-dim:#9aa0a8;
    --text-faint:#5c6067;
    --radius:16px;
    --font-display:'Space Grotesk', sans-serif;
    --font-mono:'JetBrains Mono', monospace;
    --font-body:'Inter', sans-serif;
    --ease:cubic-bezier(.16,.84,.32,1);
  }

  *{ box-sizing:border-box; margin:0; padding:0; }
  html{ scroll-behavior:smooth; background:var(--bg); }
  body{
    background:var(--bg);
    color:var(--text);
    font-family:var(--font-body);
    line-height:1.6;
    overflow-x:hidden;
    -webkit-font-smoothing:antialiased;
  }
  ::selection{ background:var(--accent); color:#0c0d10; }
  a{ color:inherit; text-decoration:none; }
  img{ max-width:100%; display:block; }
  section{ position:relative; scroll-margin-top:88px; }

  .wrap{ max-width:1200px; margin:0 auto; padding:0 48px; }
  @media (max-width:768px){ .wrap{ padding:0 24px; } }

  .eyebrow{
    font-family:var(--font-mono);
    font-size:12.5px;
    letter-spacing:.14em;
    text-transform:uppercase;
    color:var(--accent);
    display:flex;
    align-items:center;
    gap:10px;
  }
  .eyebrow::before{
    content:'';
    width:22px; height:1px;
    background:var(--accent);
  }

  /* ---------- PAGE WIPE TRANSITION ---------- */
  #page-wipe{
    position:fixed; inset:0;
    background:var(--bg);
    z-index:999;
    transform:scaleY(0);
    transform-origin:bottom;
    pointer-events:none;
    display:flex;
    align-items:center;
    justify-content:center;
  }
  #page-wipe.cover{
    transform:scaleY(1);
    transform-origin:bottom;
    transition:transform .55s var(--ease);
  }
  #page-wipe.reveal{
    transform:scaleY(0);
    transform-origin:top;
    transition:transform .55s var(--ease);
  }
  #page-wipe span{
    font-family:var(--font-mono);
    color:var(--accent);
    font-size:13px;
    letter-spacing:.3em;
    text-transform:uppercase;
    opacity:0;
  }
  #page-wipe.cover span{ opacity:1; transition:opacity .3s ease .25s; }

  /* ---------- NAV ---------- */
  header{
    position:fixed; top:0; left:0; right:0;
    z-index:200;
    background:rgba(12,13,16,.7);
    backdrop-filter:blur(14px);
    -webkit-backdrop-filter:blur(14px);
    border-bottom:1px solid var(--line-soft);
  }
  nav.wrap{
    display:flex; align-items:center; justify-content:space-between;
    height:76px;
  }
  .logo{
    font-family:var(--font-mono);
    font-weight:600;
    font-size:15px;
    letter-spacing:.08em;
    display:flex; align-items:center; gap:8px;
  }
  .logo .dot{ width:7px; height:7px; border-radius:50%; background:var(--accent); box-shadow:0 0 10px var(--accent); }
  .nav-links{ display:flex; gap:38px; list-style:none; }
  .nav-links a{
    font-family:var(--font-mono);
    font-size:12.5px;
    letter-spacing:.1em;
    text-transform:uppercase;
    color:var(--text-dim);
    position:relative;
    padding:6px 0;
    transition:color .3s var(--ease);
  }
  .nav-links a::after{
    content:'';
    position:absolute; left:0; right:100%; bottom:0;
    height:1px; background:var(--accent);
    transition:right .35s var(--ease);
  }
  .nav-links a:hover, .nav-links a.active{ color:var(--text); }
  .nav-links a:hover::after, .nav-links a.active::after{ right:0; }
  .nav-toggle{ display:none; background:none; border:none; color:var(--text); cursor:pointer; }

  @media (max-width:860px){
    .nav-links{
      position:fixed; top:76px; left:0; right:0;
      background:var(--bg-panel);
      flex-direction:column; gap:0;
      max-height:0; overflow:hidden;
      transition:max-height .4s var(--ease);
      border-bottom:1px solid var(--line);
    }
    .nav-links.open{ max-height:340px; }
    .nav-links li{ width:100%; }
    .nav-links a{ display:block; padding:16px 24px; }
    .nav-links a::after{ display:none; }
    .nav-toggle{ display:block; }
  }

  /* ---------- HERO ---------- */
  #home{
    height:100vh; min-height:640px;
    position:relative;
    overflow:hidden;
    display:flex; flex-direction:column; justify-content:flex-end;
    background:var(--bg);
  }
  #home video{
    position:absolute; inset:0;
    width:100%; height:100%;
    object-fit:cover;
    z-index:0;
    pointer-events:none;
  }
  .scene{ position:absolute; inset:0; z-index:1; pointer-events:none; }
  .scene .glow,
  .scene .grid-floor,
  .scene .rig,
  .scene .figure{ display:none; }

  .hero-content{ position:relative; z-index:5; padding:0 48px 74px; }
  @media (max-width:768px){ .hero-content{ padding:0 24px 56px; } }


  h1.hero-name{
    font-family:var(--font-display);
    font-weight:700;
    font-size:clamp(48px, 10vw, 128px);
    line-height:.95;
    letter-spacing:-.02em;
    opacity:0; transform:translateY(24px);
    animation:riseIn .9s var(--ease) .35s forwards;
  }
  .hero-tagline{
    margin-top:20px;
    font-family:var(--font-mono);
    font-size:14px;
    color:var(--text-dim);
    display:flex; gap:14px; flex-wrap:wrap;
    opacity:0; transform:translateY(16px);
    animation:riseIn .9s var(--ease) .55s forwards;
  }
  .hero-tagline b{ color:var(--text); font-weight:500; }
  .hero-tagline .sep{ color:var(--accent); }

  @keyframes riseIn{ to{ opacity:1; transform:translateY(0); } }

  .scroll-cue{
    position:absolute; left:48px; bottom:28px; z-index:5;
    font-family:var(--font-mono); font-size:11px; letter-spacing:.16em;
    color:var(--text-faint); text-transform:uppercase;
    display:flex; align-items:center; gap:10px;
  }
  .scroll-cue .bar{ width:1px; height:34px; background:linear-gradient(var(--accent), transparent); animation:scrollPulse 1.8s ease-in-out infinite; }
  @keyframes scrollPulse{ 0%,100%{ opacity:.3; } 50%{ opacity:1; } }
  @media (max-width:768px){ .scroll-cue{ left:24px; } }

  .sound-toggle{
    position:absolute; right:48px; bottom:28px; z-index:5;
    width:44px; height:44px; border-radius:50%;
    border:1px solid var(--line);
    background:rgba(255,255,255,.03);
    display:flex; align-items:center; justify-content:center;
    cursor:pointer;
    transition:border-color .3s, background .3s;
  }
  .sound-toggle:hover{ border-color:var(--accent); }
  .sound-toggle svg{ width:18px; height:18px; stroke:var(--text-dim); }
  .sound-toggle.on svg{ stroke:var(--accent); }
  @media (max-width:768px){ .sound-toggle{ right:24px; } }

  /* ---------- SECTION HEADS ---------- */
  .section-head{ margin-bottom:56px; }
  .section-title{
    font-family:var(--font-display);
    font-weight:600;
    font-size:clamp(34px, 5vw, 56px);
    letter-spacing:-.01em;
    margin-top:14px;
  }

/* ============================= ABOUT ============================= */
#about{background:var(--bg-alt);border-top:1px solid var(--line);}
.about-grid{display:grid;grid-template-columns:.85fr 1.15fr;gap:64px;align-items:center;}
@media(max-width:860px){.about-grid{grid-template-columns:1fr;gap:44px;}}
.photo-panel{
  aspect-ratio:4/5;border-radius:18px;position:relative;overflow:hidden;
  background:
    radial-gradient(120% 120% at 30% 10%, rgba(139,107,255,.5), transparent 55%),
    radial-gradient(120% 120% at 80% 90%, rgba(66,233,200,.35), transparent 55%),
    linear-gradient(160deg,#1a1a28,#0b0b12);
  border:1px solid var(--line);
  display:flex;align-items:flex-end;justify-content:center;
}
.photo-panel img{
  width:100%;height:100%;object-fit:cover;object-position:center;display:block;
}
.photo-panel::before{
  content:"";position:absolute;inset:0;background:linear-gradient(180deg, rgba(0,0,0,.08), rgba(0,0,0,.28));pointer-events:none;z-index:1;
}
.photo-panel > *{position:relative;z-index:2;}
.photo-mark{font-family:'Sora',sans-serif;font-weight:800;font-size:clamp(70px,14vw,150px);color:rgba(255,255,255,.08);letter-spacing:-.03em;padding-bottom:0;line-height:.8;}
.photo-tag{position:absolute;top:18px;left:18px;font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.16em;color:var(--cyan);border:1px solid rgba(66,233,200,.4);padding:5px 10px;border-radius:20px;text-transform:uppercase;}
.about-text p{font-size:17px;line-height:1.85;color:#c6c6d4;margin-top:20px;max-width:52ch;}
.about-text p:first-of-type{margin-top:24px;}

/* stat/role strip */
.about-meta{display:flex;gap:34px;margin-top:36px;flex-wrap:wrap;}
.about-meta div{border-left:2px solid var(--violet);padding-left:14px;}
.about-meta b{display:block;font-family:'Sora',sans-serif;font-size:15px;}
.about-meta span{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--muted);letter-spacing:.08em;text-transform:uppercase;}

  /* ---------- TOOLS / AI / SKILLS ---------- */
  #tools{ background:var(--bg-panel-2); padding:80px 0; border-top:1px solid var(--line-soft); border-bottom:1px solid var(--line-soft); }
  .tool-row{
    display:grid; grid-template-columns:150px 1fr;
    gap:28px; align-items:center;
    padding:26px 0;
    border-bottom:1px solid var(--line-soft);
  }
  .tool-row:last-child{ border-bottom:none; }
  .tool-row .label{
    font-family:var(--font-mono);
    font-size:13px; letter-spacing:.14em; text-transform:uppercase;
    color:var(--text-faint);
  }
  .pills{ display:flex; flex-wrap:wrap; gap:12px; }
  .pill{
    font-family:var(--font-mono);
    font-size:13px;
    padding:9px 18px;
    border-radius:999px;
    border:1px solid var(--line);
    color:var(--text-dim);
    transition:border-color .3s, color .3s, transform .3s;
  }
  .pill:hover{ border-color:var(--accent); color:var(--text); transform:translateY(-2px); }
  @media (max-width:640px){ .tool-row{ grid-template-columns:1fr; gap:12px; } }

  /* ---------- PROJECTS ---------- */
  #project{ padding:150px 0 120px; background:var(--bg); }
  .project{
    display:grid; grid-template-columns:1fr 1fr;
    gap:56px; align-items:center;
    padding:56px 0;
    border-bottom:1px solid var(--line-soft);
  }
  .project:first-of-type{ padding-top:0; }
  .project:nth-of-type(even) .project-text{ order:2; }
  @media (max-width:860px){
    .project{ grid-template-columns:1fr; gap:28px; }
    .project:nth-of-type(even) .project-text{ order:0; }
  }
  .project-index{
    font-family:var(--font-mono); font-size:15px; color:var(--accent);
    display:flex; align-items:center; gap:14px; margin-bottom:16px;
  }
  .project-index::after{ content:''; height:1px; width:44px; background:var(--line); }
  .project-title{ font-family:var(--font-display); font-weight:600; font-size:28px; margin-bottom:14px; }
  .project-desc{ color:var(--text-dim); max-width:440px; }
  .project-tags{ display:flex; gap:10px; margin-top:20px; flex-wrap:wrap; }
  .project-tags span{ font-family:var(--font-mono); font-size:11px; color:var(--text-faint); border:1px solid var(--line-soft); padding:5px 10px; border-radius:6px; }

  .project-media{ perspective:1400px; }
.project-media{
    perspective:1400px;
}

.project-media-inner{
    aspect-ratio:4/3;
    border-radius:18px;
    overflow:hidden;
    border:1px solid var(--line);
    background:var(--bg-panel);
    transform:rotateY(-85deg);
    opacity:0;
    transform-origin:left center;
    transition:transform 1s var(--ease), opacity .8s ease;
}

.project.in-view .project-media-inner{
    transform:rotateY(0);
    opacity:1;
}
/* Carousel */
.carousel{
    position:relative;
    width:100%;
    height:100%;
}
.slides{
    width:100%;
    height:100%;
    position:relative;
}
.slide{
    position:absolute;
    width:100%;
    height:100%;
    object-fit:cover;
    opacity:0;
    transition:opacity .5s ease;
}
.slide.active{
    opacity:1;
}
.prev,
.next{
    position:absolute;
    top:50%;
    transform:translateY(-50%);
    width:42px;
    height:42px;
    border:none;
    border-radius:50%;
    background:rgba(0,0,0,.55);
    color:white;
    cursor:pointer;
    font-size:20px;
    transition:.3s;
}
.prev:hover,
.next:hover{
    background:var(--accent);
}

.prev{
    left:15px;
}

.next{

    right:15px;
}
  .project.in-view .project-media-inner{ transform:rotateY(0deg); opacity:1; }
  .project-media-inner svg{ width:46px; height:46px; stroke:var(--accent2); opacity:.7; }
  .project-media-inner span{ font-family:var(--font-mono); font-size:11px; letter-spacing:.1em; color:var(--text-faint); text-transform:uppercase; }

  /* ---------- GALLERY ---------- */
  #gallery{ padding:140px 0 20px; background:var(--bg); overflow:hidden; }
  .gallery-block{ margin-bottom:90px; }
  .gallery-heading{
    display:flex; align-items:center; justify-content:space-between;
    margin-bottom:34px; flex-wrap:wrap; gap:16px;
  }
  .gallery-heading h3{ font-family:var(--font-display); font-size:24px; font-weight:600; }
  .gallery-heading .dir{ font-family:var(--font-mono); font-size:11.5px; color:var(--text-faint); letter-spacing:.1em; text-transform:uppercase; display:flex; align-items:center; gap:8px; }
  .gallery-heading .dir svg{ width:16px; height:16px; stroke:var(--accent); }

  .marquee{ width:100%; overflow:hidden; }
  .marquee-track{
    display:flex; gap:20px; width:max-content;
  }
  .marquee-track.ltr{ animation:moveLTR 26s linear infinite; }
  .marquee-track.rtl{ animation:moveRTL 26s linear infinite; }
  .marquee:hover .marquee-track{ animation-play-state:paused; }
  @keyframes moveLTR{ from{ transform:translateX(-50%); } to{ transform:translateX(0); } }
  @keyframes moveRTL{ from{ transform:translateX(0); } to{ transform:translateX(-50%); } }

 .tile{
    position:relative;
    width:230px;
    height:290px;
    overflow:hidden;
    border-radius:12px;
    border:1px solid var(--line);
    background:#111;
}

.tile img{
    width:100%;
    height:100%;
    object-fit:contain;   /* Entire image visible */
    object-position:center;
    display:block;
}
.tile:hover{
    transform:translateY(-6px);
    border-color:var(--accent2);
}
  .tile svg{ width:34px; height:34px; stroke:var(--text-faint); }
  .tile .idx{
    position:absolute; left:14px; bottom:14px;
    font-family:var(--font-mono); font-size:11px; color:var(--text-faint);
  }
  .tile .expand{
    position:absolute; top:12px; right:12px;
    width:26px; height:26px; border-radius:50%;
    border:1px solid var(--line);
    display:flex; align-items:center; justify-content:center;
    background:rgba(12,13,16,.5);
  }
  .tile .expand svg{ width:12px; height:12px; stroke:var(--accent); }
  .tile.b{ background:linear-gradient(160deg, rgba(61,214,255,.08), var(--bg-panel)); }
  .tile.c{ background:linear-gradient(160deg, rgba(255,122,41,.08), var(--bg-panel)); }

  /* ---------- LIGHTBOX ---------- */
  #lightbox{
    position:fixed; inset:0; z-index:500;
    background:rgba(6,7,9,.75);
    display:flex; align-items:center; justify-content:center;
    opacity:0; pointer-events:none;
    transition:opacity .35s ease;
    padding:24px;
  }
  #lightbox.open{ opacity:1; pointer-events:auto; }
  .lightbox-content{
    width:min(760px, 90vw);
    max-height:min(80vh, 700px);
    border-radius:22px;
    border:1px solid var(--line);
    background:linear-gradient(155deg, var(--bg-panel-2), var(--bg-panel));
    padding:24px;
    display:flex; flex-direction:column; align-items:center; gap:18px;
    position:relative;
    overflow:hidden;
    box-shadow:0 40px 110px rgba(0,0,0,.45);
    transform:scale(.95);
    transition:transform .35s var(--ease);
  }
  #lightbox.open .lightbox-content{ transform:scale(1); }
  .lightbox-content img{
    width:100%;
    max-height:72vh;
    object-fit:contain;
    border-radius:16px;
    display:block;
  }
  .lightbox-content p{
    margin:0;
    font-family:var(--font-mono);
    color:var(--text-faint);
    font-size:13px;
    letter-spacing:.12em;
    text-transform:uppercase;
  }
  .lightbox-close{
    position:absolute; top:16px; right:16px;
    width:36px; height:36px; border-radius:50%;
    border:1px solid var(--line); background:rgba(12,13,16,.85); cursor:pointer;
    display:flex; align-items:center; justify-content:center;
    z-index:1;
  }
  .lightbox-close svg{ width:16px; height:16px; stroke:var(--text); }

  /* ---------- RESUME ---------- */
  #resume{ padding:150px 0; background:var(--bg-panel-2); border-top:1px solid var(--line-soft); border-bottom:1px solid var(--line-soft); text-align:center; }
  #resume .section-title{ margin-top:14px; }
  #resume .sub{ color:var(--text-dim); max-width:460px; margin:20px auto 40px; }
  .resume-actions{ display:flex; gap:18px; justify-content:center; align-items:center; flex-wrap:wrap; }
  .btn{
    font-family:var(--font-mono); font-size:13px; letter-spacing:.08em; text-transform:uppercase;
    padding:16px 34px; border-radius:8px;
    background:var(--accent); color:#0c0d10; font-weight:600;
    transition:transform .3s var(--ease), box-shadow .3s;
    cursor:pointer; border:none; display:inline-flex; align-items:center; gap:10px;
  }
  .btn:hover{ transform:translateY(-3px); box-shadow:0 14px 30px -10px var(--accent-soft); }
  .icon-btn{
    width:52px; height:52px; border-radius:50%;
    border:1px solid var(--line); background:transparent;
    display:flex; align-items:center; justify-content:center; cursor:pointer;
    transition:border-color .3s, transform .3s;
  }
  .icon-btn:hover{ border-color:var(--accent2); transform:translateY(-3px); }
  .icon-btn svg{ width:18px; height:18px; stroke:var(--text); }

  /* ---------- CONTACT ---------- */
  #contact{ padding:150px 0 110px; background:var(--bg); text-align:center; }
  #contact .section-head{ display:flex; flex-direction:column; align-items:center; }
  #contact .sub{ color:var(--text-dim); max-width:420px; margin:20px auto 0; }
  .social-grid{
    display:grid; grid-template-columns:repeat(5, minmax(0, 1fr)); gap:14px;
    margin-top:56px;
  }
  @media (max-width:860px){ .social-grid{ grid-template-columns:repeat(5, minmax(0, 1fr)); } }
  @media (max-width:760px){ .social-grid{ grid-template-columns:repeat(4, minmax(0, 1fr)); } }
  @media (max-width:520px){ .social-grid{ grid-template-columns:repeat(3, minmax(0, 1fr)); } }
  .social-tile{
    aspect-ratio:1; border-radius:12px;
    border:1px solid var(--line);
    display:flex; align-items:center; justify-content:center;
    transition:border-color .3s, transform .3s, background .3s;
  }
  .social-tile:hover{ border-color:var(--accent); transform:translateY(-4px); background:var(--accent-soft); }
  .social-tile svg{ width:20px; height:20px; stroke:var(--text-dim); transition:stroke .3s; }
  .social-tile:hover svg{ stroke:var(--accent); }

  footer{ padding:34px 0; text-align:center; font-family:var(--font-mono); font-size:11.5px; color:var(--text-faint); letter-spacing:.06em; }

  /* reveal-on-scroll generic */
  .rise{ opacity:0; transform:translateY(28px); transition:opacity .8s var(--ease), transform .8s var(--ease); }
  .rise.in-view{ opacity:1; transform:translateY(0); }
</style>
</head>
<body>

  <div id="page-wipe"><span>NITISH</span></div>

  <header>
    <nav class="wrap">
      <a href="#home" class="logo"><span class=""></span> </a>
      <ul class="nav-links" id="navLinks">
        <li><a href="#about" data-nav>About Me</a></li>
        <li><a href="#project" data-nav>Project</a></li>
        <li><a href="#gallery" data-nav>Gallery</a></li>
        <li><a href="#resume" data-nav>Resume</a></li>
        <li><a href="#contact" data-nav>Get in Touch</a></li>
      </ul>
      <button class="nav-toggle" id="navToggle" aria-label="Toggle menu">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </nav>
  </header>

